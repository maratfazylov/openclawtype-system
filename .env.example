# Choose any LangChain-supported tool-calling chat model.
OPENCLAW_PROVIDER=openrouter
OPENCLAW_MODEL=openrouter:tencent/hy3:free
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M2
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Required by your selected provider.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# Optional: tracing and Deep Agents UI access to remote deployments.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Optional Telegram connector. Use dry_run=True until these are configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Jenkins connector for the test DevOps endpoint.
JENKINS_JOB_URL=https://devops.brojs.ru/job/marat/
JENKINS_JOB_TOKEN=
JENKINS_USERNAME=
JENKINS_API_TOKEN=
# Explicit opt-in for notebooks that trigger a real Jenkins build.
OPENCLAW_RUN_REAL_JENKINS_PIPELINE=1

# Optional VK connector. Use dry_run=True until these are configured.
VK_ACCESS_TOKEN=
VK_API_VERSION=5.199

# Optional VK -> LangGraph bridge.
LANGGRAPH_URL=http://127.0.0.1:2024
LANGGRAPH_ASSISTANT_ID=openclaw_notebook
VK_BRIDGE_DRY_RUN=1
VK_BRIDGE_REPLY_TO_VK=0
VK_BRIDGE_WAIT_FOR_RUN=1
VK_BRIDGE_POLL_SECONDS=5
VK_BRIDGE_CONVERSATION_COUNT=10
VK_BRIDGE_STATE_PATH=.openclaw_vk_bridge_state.json

# Local shell mode is powerful and unsafe outside trusted workspaces.
OPENCLAW_ENABLE_LOCAL_SHELL=0
OPENCLAW_WORKSPACE=.
