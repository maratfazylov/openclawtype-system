# Model provider keys. If OMNIROUTE_API_KEY is set, stages use local OmniRoute:
# http://127.0.0.1:20128/v1 with model=auto.
# Otherwise the workshop code falls back to OpenRouter: openrouter:tencent/hy3:free.
OMNIROUTE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# Optional tracing.
LANGSMITH_API_KEY=

# Optional Telegram connector credentials.
TELEGRAM_BOT_TOKEN=

# Jenkins credentials for https://devops.brojs.ru/job/marat/.
JENKINS_JOB_TOKEN=
JENKINS_USERNAME=
JENKINS_API_TOKEN=

# VK API token.
VK_ACCESS_TOKEN=
