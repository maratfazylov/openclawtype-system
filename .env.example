# Choose any LangChain-supported tool-calling chat model.
OPENCLAW_MODEL=openrouter:openai/gpt-oss-120b:free

# Required by your selected provider.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: tracing and Deep Agents UI access to remote deployments.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Optional Telegram connector. Use dry_run=True until these are configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local shell mode is powerful and unsafe outside trusted workspaces.
OPENCLAW_ENABLE_LOCAL_SHELL=0
OPENCLAW_WORKSPACE=.
